<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:padding="8dp" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
    <ImageView android:id="@+id/ivResultThumb" android:layout_width="80dp" android:layout_height="80dp" android:scaleType="centerCrop"/>
    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:orientation="vertical" android:layout_height="wrap_content" android:paddingStart="8dp">
        <TextView android:id="@+id/tvResultFilename" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="filename"/>
        <TextView android:id="@+id/tvResultAlbum" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="album"/>
    </LinearLayout>
</LinearLayout>
