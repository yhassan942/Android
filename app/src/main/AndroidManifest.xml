<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.android">

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.PhotosApp">

        <!-- Main launcher activity -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Other app activities -->
        <activity android:name=".activities.AlbumActivity" android:exported="false"/>
        <!-- <activity android:name=".activities.MainActivity" android:exported="true"/>-->
        <activity android:name=".activities.PhotoActivity" android:exported="false"/>
        <activity android:name=".activities.SearchActivity" android:exported="false"/>


    </application>

</manifest>

